# Kopiera till .env och fyll i. .env checkas ALDRIG in (se .gitignore).
# Alla AI-funktioner är VALFRIA — simuleringen fungerar helt utan nyckel.

# --- AI-leverantör -----------------------------------------------------------
# Välj var AI-svaren kommer ifrån. Lämna tomt för standard (Claude/Anthropic).
#   anthropic  = Claude via Anthropics API (default)
#   openai     = valfri OpenAI-kompatibel endpoint: Ollama (lokalt, gratis),
#                OpenAI, Groq, Together, Mistral, Gemini m.fl.
# AI_PROVIDER=anthropic

# Modellnamn. Default: claude-haiku-4-5 (anthropic) resp. llama3.1 (openai).
# AI_MODEL=claude-haiku-4-5

# API-nyckel för vald leverantör. För anthropic funkar även ANTHROPIC_API_KEY nedan.
# Lokala Ollama-servrar behöver ingen nyckel.
# AI_API_KEY=

# Endpoint för openai-spåret (ignoreras av anthropic).
# Ollama lokalt (default):     http://localhost:11434/v1
# OpenAI:                       https://api.openai.com/v1
# Groq:                         https://api.groq.com/openai/v1
# AI_BASE_URL=http://localhost:11434/v1

# Timeout per AI-anrop i sekunder (lokala modeller kan vara sega).
# AI_TIMEOUT=120

# Bakåtkompatibel: Anthropic-nyckel (används om AI_PROVIDER=anthropic och AI_API_KEY saknas).
# ANTHROPIC_API_KEY=din-egen-nyckel

# --- Drift (valfritt) --------------------------------------------------------
# APP_ENV=production
# ADMIN_PASSWORD=byt-detta
# ALLOWED_ORIGINS=https://din.domän
# MAX_CONTENT_KB=256
# FLASK_DEBUG=0
# PORT=5800
